<% for (const item of items) { %>
<%
  let authorStr = '';
  if (item.author) {
    if (Array.isArray(item.author)) {
      authorStr = item.author.map(a => typeof a === 'object' ? a.name : a).join(', ');
    } else {
      authorStr = String(item.author);
    }
  }
  const venue = item.venue || '';
  const pdf = item.pdf || '';
  const code = item.code || '';
  const slides = item.slides || '';
  const preprint = item.preprint || '';
%>
<div class="pub-listing-item">
  <div class="pub-title"><a href="<%= item.path %>"><%- item.title %></a></div>
  <div class="pub-authors"><%- authorStr %></div>
  <% if (venue) { %><div class="pub-venue"><%- venue %></div><% } %>
  <% if (preprint) { %><a href="<%= preprint %>" class="pub-link-btn" target="_blank">Preprint</a><% } %>
  <% if (pdf) { %><a href="<%= pdf %>" class="pub-link-btn" target="_blank">PDF</a><% } %>
  <% if (code) { %><a href="<%= code %>" class="pub-link-btn" target="_blank">Code</a><% } %>
  <% if (slides) { %><a href="<%= slides %>" class="pub-link-btn" target="_blank">Slides</a><% } %>
</div>
<% } %>
